<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Solas — Stop tracking. Start talking.</title>
<meta name="description" content="One conversation replaces 10 health apps. Solas learns you, remembers everything, and tells you what actually matters.">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,300&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#080810;--bg2:#0E0E1A;--bg3:#141420;
  --card:rgba(255,255,255,0.04);--border:rgba(255,255,255,0.08);--border2:rgba(255,255,255,0.12);
  --text:#F0EFF8;--text2:rgba(240,239,248,0.55);--text3:rgba(240,239,248,0.30);
  --accent:#0A84FF;--green:#30D158;--orange:#FF9F0A;--purple:#BF5AF2;--red:#FF453A;
  --serif:'Instrument Serif',Georgia,serif;--sans:'DM Sans',system-ui,sans-serif;
}
html{scroll-behavior:smooth}
body{background:var(--bg);color:var(--text);font-family:var(--sans);font-size:16px;line-height:1.6;-webkit-font-smoothing:antialiased;overflow-x:hidden}

/* Nav */
nav{position:fixed;top:0;left:0;right:0;z-index:100;display:flex;align-items:center;justify-content:space-between;padding:20px 48px;background:rgba(8,8,16,0.88);backdrop-filter:blur(24px);border-bottom:0.5px solid var(--border)}
.nav-logo{font-family:var(--serif);font-size:22px;color:var(--text);text-decoration:none}
.nav-links{display:flex;align-items:center;gap:32px;list-style:none}
.nav-links a{color:var(--text2);text-decoration:none;font-size:14px;transition:color 0.2s}
.nav-links a:hover{color:var(--text)}
.nav-cta{background:var(--accent)!important;color:white!important;padding:8px 22px!important;border-radius:100px!important;font-weight:500!important;font-size:14px!important;transition:opacity 0.2s!important}
.nav-cta:hover{opacity:0.85!important}

/* Hero */
.hero{min-height:100vh;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;padding:140px 40px 80px;position:relative;overflow:hidden}
.glow-1{position:absolute;width:700px;height:700px;border-radius:50%;background:radial-gradient(circle,rgba(10,132,255,0.10) 0%,transparent 70%);top:40%;left:50%;transform:translate(-50%,-50%);pointer-events:none}
.glow-2{position:absolute;width:500px;height:500px;border-radius:50%;background:radial-gradient(circle,rgba(191,90,242,0.07) 0%,transparent 70%);top:65%;left:25%;transform:translate(-50%,-50%);pointer-events:none}
.beta-pill{display:inline-flex;align-items:center;gap:8px;background:rgba(10,132,255,0.12);border:0.5px solid rgba(10,132,255,0.3);border-radius:100px;padding:6px 18px;font-size:13px;color:#60A5FA;font-weight:500;margin-bottom:36px;letter-spacing:0.2px}
.beta-dot{width:6px;height:6px;border-radius:50%;background:#60A5FA;animation:blink 2s infinite}
@keyframes blink{0%,100%{opacity:1}50%{opacity:0.35}}
.hero h1{font-family:var(--serif);font-size:clamp(52px,8vw,96px);line-height:1.04;letter-spacing:-2.5px;margin-bottom:24px;max-width:860px;position:relative}
.hero h1 em{font-style:italic;color:var(--text2)}
.hero-sub{font-size:clamp(16px,2vw,20px);color:var(--text2);max-width:500px;line-height:1.65;margin-bottom:48px;font-weight:300}
.hero-actions{display:flex;align-items:center;gap:14px;flex-wrap:wrap;justify-content:center}
.btn-primary{background:var(--accent);color:white;padding:14px 34px;border-radius:100px;font-size:16px;font-weight:500;text-decoration:none;transition:opacity 0.2s,transform 0.2s;display:inline-flex;align-items:center;gap:8px}
.btn-primary:hover{opacity:0.88;transform:translateY(-1px)}
.btn-ghost{color:var(--text2);padding:14px 24px;border-radius:100px;font-size:16px;font-weight:400;text-decoration:none;border:0.5px solid var(--border2);transition:all 0.2s}
.btn-ghost:hover{color:var(--text);border-color:rgba(255,255,255,0.25)}
.hero-note{margin-top:18px;font-size:13px;color:var(--text3)}

/* Phone */
.phone-wrap{display:flex;justify-content:center;padding:0 40px 100px}
.phone{width:286px;background:#080812;border-radius:46px;border:0.5px solid rgba(255,255,255,0.14);padding:14px;box-shadow:0 48px 120px rgba(0,0,0,0.65),0 0 0 0.5px rgba(255,255,255,0.05)}
.phone-notch{width:82px;height:26px;background:#080812;border-radius:0 0 18px 18px;margin:0 auto 14px;position:relative;z-index:2}
.phone-screen{background:#0C0C18;border-radius:36px;padding:20px 16px;min-height:500px}
.msg-user{display:flex;justify-content:flex-end;margin-bottom:12px}
.msg-user span{background:var(--accent);border-radius:16px 16px 4px 16px;padding:10px 14px;font-size:13px;color:white;line-height:1.5;max-width:82%}
.msg-ai{display:flex;gap:8px;align-items:flex-start;margin-bottom:12px}
.ai-dot{width:26px;height:26px;border-radius:50%;background:var(--accent);display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;color:white;flex-shrink:0;margin-top:2px}
.msg-ai span{background:rgba(255,255,255,0.07);border-radius:16px 16px 16px 4px;padding:10px 14px;font-size:13px;color:rgba(255,255,255,0.85);line-height:1.5}
.energy-card{background:rgba(255,255,255,0.05);border:0.5px solid rgba(255,255,255,0.10);border-radius:16px;padding:14px;margin-top:10px}
.e-label{font-size:9px;color:var(--text3);font-weight:700;letter-spacing:1px;margin-bottom:6px}
.e-score{font-size:38px;font-weight:700;color:var(--green);letter-spacing:-2px;line-height:1}
.e-sub{font-size:11px;color:var(--text2);margin-top:3px;margin-bottom:12px}
.macro{display:flex;align-items:center;gap:8px;margin-bottom:7px}
.macro-lbl{font-size:10px;color:var(--text2);width:48px}
.macro-track{flex:1;height:4px;background:rgba(255,255,255,0.08);border-radius:2px;overflow:hidden}
.macro-fill{height:4px;border-radius:2px}
.macro-val{font-size:10px;color:var(--text2);width:32px;text-align:right}

/* Sections */
.section{padding:100px 48px;max-width:1120px;margin:0 auto}
.section-wide{padding:100px 0;background:var(--bg2)}
.section-wide-inner{max-width:1120px;margin:0 auto;padding:0 48px}
.label{font-size:11px;font-weight:600;letter-spacing:1.5px;color:var(--text3);text-transform:uppercase;margin-bottom:14px}
.title{font-family:var(--serif);font-size:clamp(38px,5vw,60px);line-height:1.08;letter-spacing:-1.5px;margin-bottom:18px}
.sub{font-size:18px;color:var(--text2);font-weight:300;max-width:520px;line-height:1.65}

/* Features grid */
.feat-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:1px;background:var(--border);border:0.5px solid var(--border);border-radius:24px;overflow:hidden;margin-top:56px}
.feat{background:var(--bg2);padding:36px 32px;transition:background 0.2s}
.feat:hover{background:var(--bg3)}
.feat-icon{width:44px;height:44px;border-radius:12px;display:flex;align-items:center;justify-content:center;margin-bottom:20px;font-size:20px}
.feat-title{font-size:17px;font-weight:500;margin-bottom:10px}
.feat-desc{font-size:14px;color:var(--text2);line-height:1.65;font-weight:300}

/* How it works */
.how-grid{display:grid;grid-template-columns:1fr 1fr;gap:80px;align-items:center;margin-top:56px}
.steps{display:flex;flex-direction:column}
.step{display:flex;gap:20px;padding:28px 0;border-bottom:0.5px solid var(--border)}
.step:last-child{border-bottom:none}
.step-n{width:32px;height:32px;border-radius:50%;background:var(--card);border:0.5px solid var(--border2);display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:500;color:var(--text3);flex-shrink:0;margin-top:2px}
.step h3{font-size:16px;font-weight:500;margin-bottom:6px}
.step p{font-size:14px;color:var(--text2);font-weight:300;line-height:1.65}
.demo{background:var(--bg2);border:0.5px solid var(--border);border-radius:24px;padding:28px;display:flex;flex-direction:column;gap:14px}
.demo-hdr{display:flex;align-items:center;gap:10px;padding-bottom:16px;border-bottom:0.5px solid var(--border);margin-bottom:4px}
.demo-av{width:32px;height:32px;border-radius:50%;background:var(--accent);display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:700;color:white}
.demo-name{font-size:14px;font-weight:500}
.demo-status{font-size:12px;color:var(--text3)}

/* Wearables */
.wearable-row{display:flex;flex-wrap:wrap;gap:12px;margin-top:40px}
.wearable-pill{display:flex;align-items:center;gap:10px;background:var(--bg2);border:0.5px solid var(--border);border-radius:100px;padding:10px 20px}
.wearable-dot{width:8px;height:8px;border-radius:50%}
.wearable-name{font-size:14px;font-weight:500}
.wearable-status{font-size:12px;color:var(--text3)}

/* Pricing */
.pricing-grid{display:grid;grid-template-columns:1fr 1fr;gap:16px;max-width:680px;margin:56px auto 0}
.price-card{background:var(--bg2);border:0.5px solid var(--border);border-radius:24px;padding:36px 32px}
.price-card.pro{background:var(--accent);border-color:var(--accent)}
.price-plan{font-size:12px;font-weight:700;letter-spacing:1px;color:var(--text3);margin-bottom:12px}
.price-card.pro .price-plan{color:rgba(255,255,255,0.65)}
.price-num{font-family:var(--serif);font-size:52px;letter-spacing:-2px;line-height:1;margin-bottom:4px}
.price-per{font-size:14px;color:var(--text2);margin-bottom:28px}
.price-card.pro .price-per{color:rgba(255,255,255,0.65)}
.price-list{list-style:none;display:flex;flex-direction:column;gap:10px;margin-bottom:28px}
.price-list li{font-size:14px;color:var(--text2);display:flex;align-items:center;gap:8px}
.price-card.pro .price-list li{color:rgba(255,255,255,0.88)}
.price-list li::before{content:'✓';color:var(--green);font-weight:700;flex-shrink:0}
.price-card.pro .price-list li::before{color:white}
.price-btn{display:block;text-align:center;padding:13px 24px;border-radius:100px;font-size:15px;font-weight:500;text-decoration:none;transition:all 0.2s}
.price-btn-outline{border:0.5px solid var(--border2);color:var(--text)}
.price-btn-outline:hover{background:rgba(255,255,255,0.05)}
.price-btn-solid{background:white;color:var(--accent)}
.price-btn-solid:hover{opacity:0.92}

/* Testimonials */
.test-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:16px;margin-top:56px}
.test{background:var(--bg2);border:0.5px solid var(--border);border-radius:20px;padding:28px}
.test-quote{font-family:var(--serif);font-size:18px;line-height:1.55;color:var(--text);margin-bottom:20px;font-style:italic}
.test-author{display:flex;align-items:center;gap:12px}
.test-av{width:36px;height:36px;border-radius:50%;background:var(--card);border:0.5px solid var(--border2);display:flex;align-items:center;justify-content:center;font-size:14px;font-weight:600;color:var(--text2)}
.test-name{font-size:14px;font-weight:500}
.test-role{font-size:12px;color:var(--text3)}

/* CTA */
.cta{text-align:center;padding:140px 40px;position:relative;overflow:hidden}
.cta-glow{position:absolute;width:600px;height:600px;border-radius:50%;background:radial-gradient(circle,rgba(10,132,255,0.09) 0%,transparent 70%);top:50%;left:50%;transform:translate(-50%,-50%);pointer-events:none}
.cta h2{font-family:var(--serif);font-size:clamp(44px,7vw,80px);letter-spacing:-2.5px;line-height:1.04;margin-bottom:18px;position:relative}
.cta p{font-size:18px;color:var(--text2);font-weight:300;margin-bottom:48px;position:relative}
.waitlist{display:flex;gap:12px;max-width:440px;margin:0 auto;position:relative}
.waitlist input{flex:1;background:var(--bg2);border:0.5px solid var(--border2);border-radius:100px;padding:14px 24px;font-size:15px;color:var(--text);font-family:var(--sans);outline:none;transition:border-color 0.2s}
.waitlist input::placeholder{color:var(--text3)}
.waitlist input:focus{border-color:rgba(10,132,255,0.5)}
.waitlist button{background:var(--accent);color:white;border:none;border-radius:100px;padding:14px 28px;font-size:15px;font-weight:500;cursor:pointer;font-family:var(--sans);transition:opacity 0.2s;white-space:nowrap}
.waitlist button:hover{opacity:0.88}
.waitlist-note{font-size:13px;color:var(--text3);margin-top:14px;position:relative}

/* Footer */
footer{border-top:0.5px solid var(--border);padding:40px 48px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:20px;max-width:1120px;margin:0 auto}
.footer-logo{font-family:var(--serif);font-size:18px;color:var(--text2)}
.footer-links{display:flex;gap:24px;flex-wrap:wrap}
.footer-links a{font-size:13px;color:var(--text3);text-decoration:none;transition:color 0.2s}
.footer-links a:hover{color:var(--text2)}
.footer-copy{font-size:13px;color:var(--text3)}

/* Fade */
.fade{opacity:0;transform:translateY(18px);transition:opacity 0.65s ease,transform 0.65s ease}
.fade.in{opacity:1;transform:translateY(0)}

/* Responsive */
@media(max-width:768px){
  nav{padding:16px 20px}
  .nav-links{display:none}
  .hero{padding:110px 20px 60px}
  .section{padding:64px 20px}
  .section-wide-inner{padding:0 20px}
  .section-wide{padding:64px 0}
  .how-grid{grid-template-columns:1fr;gap:40px}
  .pricing-grid{grid-template-columns:1fr}
  .waitlist{flex-direction:column}
  footer{padding:30px 20px;flex-direction:column;align-items:flex-start}
}
</style>
</head>
<body>

<nav>
  <a href="/" class="nav-logo">Solas</a>
  <ul class="nav-links">
    <li><a href="#features">Features</a></li>
